# Ollama base URL — default when running locally
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for all agents. Must be pulled first:
#   ollama pull llama3.2        (fast, ~2GB)
#   ollama pull mistral         (great for structured JSON, ~4GB)
#   ollama pull qwen2.5:14b     (very capable, ~9GB)
#   ollama pull deepseek-r1:8b  (reasoning model, ~5GB)
OLLAMA_MODEL=llama3.2

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Minimum log level written to console and kept in the buffer
# Options: debug | info | warn | error
LOG_LEVEL=info
